# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is in .gitignore — it will never be committed.

# ==================== Database ====================
# Each service gets its own DB_URL via docker-compose.yml.
# These are only needed when running services LOCALLY (not in Docker).
DB_URL=jdbc:postgresql://localhost:5432/users_db
DB_USERNAME=
DB_PASSWORD=

# ==================== SSL Keystore ====================
SSL_KEYSTORE_PASSWORD=changeit

# ==================== JWT (minimum 32 characters) ====================
JWT_SECRET=

# ==================== Eureka Service Discovery ====================
EUREKA_USERNAME=
EUREKA_PASSWORD=

# ==================== Inter-Service URLs ====================
# Only needed when running LOCALLY. In Docker, these are set automatically
# via docker-compose.yml using container names.
USER_SERVICE_URL=https://localhost:8081
PRODUCT_SERVICE_URL=http://localhost:8082
PAYMENT_SERVICE_URL=http://localhost:8084
