# ==================== E-Commerce Platform Environment Variables ====================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# .env is in .gitignore — it will never be committed.
# Docker Compose reads .env automatically and substitutes ${VARIABLES} in docker-compose.yml.

# ==================== Database ====================
DB_USERNAME=
DB_PASSWORD=

# pgAdmin (database web UI)
PGADMIN_EMAIL=
PGADMIN_PASSWORD=

# ==================== Security ====================
SSL_KEYSTORE_PASSWORD=
JWT_SECRET=replace-with-a-random-string-at-least-32-characters

# ==================== Service Discovery ====================
EUREKA_USERNAME=
EUREKA_PASSWORD=

# ==================== Kafka ====================
# localhost:9092 for local dev, kafka:29092 for Docker
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
